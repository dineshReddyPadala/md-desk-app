generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  name                  String
  phone                 String?
  email                 String    @unique
  password              String
  role                  Role      @default(CUSTOMER)
  city                  String?
  company               String?
  designation           String?
  passwordResetToken    String?    @map("password_reset_token")
  passwordResetExpires  DateTime?  @map("password_reset_expires")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  complaints           Complaint[]
  messages             Message[]
  notifications        Notification[]
  projects             Project[]
  projectAssignments   ProjectEmployee[]
  chatParticipants     ChatParticipant[]
  chatMessagesSent     ChatMessage[]      @relation("ChatMessageSender")
  chatRoomsAsLow       ChatRoom[]         @relation("ChatRoomUserLow")
  chatRoomsAsHigh      ChatRoom[]         @relation("ChatRoomUserHigh")

  @@map("users")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

enum Role {
  ADMIN
  EMPLOYEE
  CUSTOMER
}

enum ComplaintCategory {
  PRODUCT
  SERVICE
  DELIVERY
  TECHNICAL
}

model Complaint {
  id              String             @id @default(cuid())
  complaintId     String             @unique @map("complaint_id")
  userId          String             @map("user_id")
  projectId       String?            @map("project_id")
  category        ComplaintCategory  @default(PRODUCT)
  productUsed     String             @map("product_used")
  projectLocation String             @map("project_location")
  description     String
  priority        Priority           @default(MEDIUM)
  status          ComplaintStatus    @default(RECEIVED)
  name            String?
  phone           String?
  city            String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  media           ComplaintMedia[]
  adminResponses  AdminResponse[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@map("complaints")
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum ComplaintStatus {
  RECEIVED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
}

model ComplaintMedia {
  id          String   @id @default(cuid())
  complaintId String   @map("complaint_id")
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("complaint_media")
}

model Message {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  subject     String
  message     String
  adminReply  String?  @map("admin_reply")
  repliedAt   DateTime? @map("replied_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("messages")
}

model Product {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String? @map("image_url")

  @@map("products")
}

model Dealer {
  id           String  @id @default(cuid())
  name         String
  city         String?
  phone        String?
  imageUrl     String?  @map("image_url")
  locationLat  Float?   @map("location_lat")
  locationLong Float?   @map("location_long")

  @@map("dealers")
}

enum ProjectStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model Project {
  id          String        @id @default(cuid())
  name        String        @map("name")
  description String?       @map("description")
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  documentUrl String?       @map("document_url")
  status      ProjectStatus @default(PENDING) @map("status")
  clientId    String?       @map("client_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  client      User?             @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assignees   ProjectEmployee[]
  complaints  Complaint[]
  chatRooms   ChatRoom[]

  @@index([clientId])
  @@index([status])
  @@map("projects")
}

enum ChatRoomType {
  PROJECT_GROUP
  DIRECT
}

enum ChatMessageKind {
  TEXT
  FILE
  VOICE
}

model ChatRoom {
  id         String       @id @default(cuid())
  type       ChatRoomType @map("type")
  projectId  String?      @map("project_id")
  userLowId  String?      @map("user_low_id")
  userHighId String?      @map("user_high_id")
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  project      Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userLow      User?               @relation("ChatRoomUserLow", fields: [userLowId], references: [id], onDelete: Cascade)
  userHigh     User?               @relation("ChatRoomUserHigh", fields: [userHighId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  participants ChatParticipant[]

  @@unique([userLowId, userHighId])
  @@index([projectId, type])
  @@map("chat_rooms")
}

model ChatParticipant {
  id         String    @id @default(cuid())
  roomId     String    @map("room_id")
  userId     String    @map("user_id")
  lastReadAt DateTime? @map("last_read_at")
  joinedAt   DateTime  @default(now()) @map("joined_at")

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
  @@map("chat_participants")
}

model ChatMessage {
  id             String          @id @default(cuid())
  roomId         String          @map("room_id")
  senderId       String          @map("sender_id")
  kind           ChatMessageKind @default(TEXT) @map("kind")
  body           String?         @map("body")
  attachmentUrl  String?         @map("attachment_url")
  attachmentMime String?         @map("attachment_mime")
  createdAt      DateTime        @default(now()) @map("created_at")

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

model ProjectEmployee {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  employeeId String   @map("employee_id")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee User    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([projectId, employeeId])
  @@index([employeeId])
  @@map("project_employees")
}

model AdminResponse {
  id          String   @id @default(cuid())
  complaintId String   @map("complaint_id")
  message     String
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  complaint Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)

  @@index([complaintId])
  @@map("admin_responses")
}

